RyClZBTQ6lWSzcCsgvTxQe17O9/EqOQ==" nonce=""></script><script defer="" src="./writer_files/vcd15cbe7772f49c399c6a5babf22c1241717689176015" integrity="sha512-ZpsOmlRQV6y907TI0dKBHq9Md29nnaEIPlkf84rnaERnq6zvWvPUqr2ft8M1aS28oN72PdrCzSjY4U6VaAw1EQ==" nonce="" data-cf-beacon="{&quot;rayId&quot;:&quot;9df5576a2bc7d50d&quot;,&quot;serverTiming&quot;:{&quot;name&quot;:{&quot;cfExtPri&quot;:true,&quot;cfEdge&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfL4&quot;:true,&quot;cfSpeedBrain&quot;:true,&quot;cfCacheStatus&quot;:true}},&quot;version&quot;:&quot;2025.9.1&quot;,&quot;token&quot;:&quot;ef88e2b2e2894e859fa7553dc8d0441c&quot;}" crossorigin="anonymous"></script>
<div class="g6DZMw"><div class="_2UyCZQ"></div><div class="_2UyCZQ"></div></div><div class="_3jkTAA"></div><div class="Bymw5Q"></div><div class="BghEng"><div></div><div></div></div><div id="_r_0_2" class="_pFsfA">Bảng bên</div><div id="_r_1_" class="_pFsfA">Canvas</div><div id="_r_3_" class="_pFsfA">Phần điều hướng chính chứa các nút cho các tùy chọn mức tài liệu. Để chuyển đổi giữa các nút, hãy sử dụng các phím trái và phải. Để kích hoạt, hãy nhấn Enter. Để chuyển sang khung vẽ, hãy nhấn “Ctrl+F2”.</div><div id="_r_c_" aria-hidden="true" class="_pFsfA">Hoàn tác</div><div id="_r_e_" aria-hidden="true" class="_pFsfA">Làm lại</div><div id="_r_g_" class="_pFsfA">Tiêu đề thiết kế là tên của thiết kế. Để chỉnh sửa tiêu đề thiết kế, hãy nhấn Enter. Để dừng chỉnh sửa, nhấn Escape.</div><div id="_r_i_" aria-hidden="true" class="_pFsfA">Khung vẽ là không gian nơi bạn thiết kế. Để vào trang, hãy nhấn Enter. Để vào các nhóm hoặc thành phần trên trang, hãy nhấn Enter một lần nữa. Nhấn tab để chuyển đến trang, nhóm hoặc thành phần tiếp theo. Để sử dụng thanh công cụ, hãy dùng phím “Ctrl+F1”. Sau khi chọn thành phần, hãy di chuyển thành phần bằng các phím mũi tên; xoay bằng phím “,” và phím “.”; và đổi cỡ bằng cách sử dụng các phím mũi tên cùng với phím “Ctrl”. Bạn có thể tăng cường cho tất cả các phím này bằng phím “Shift”.</div><div id="_r_k_" aria-hidden="true" class="_pFsfA">Ghi chú của người thuyết trình</div><div id="_r_s_" aria-hidden="true" class="_pFsfA">Thu phóng</div><div id="_r_u_" aria-hidden="true" class="_pFsfA">Hiển thị bộ đếm ngược</div><div id="_r_10_" class="_pFsfA">Bảng bên là nơi bạn có thể áp dụng các mẫu hoặc thêm các thành phần. Để chuyển sang khung vẽ, hãy nhấn “Ctrl+F2”.</div><div id="_r_23_" aria-hidden="true" class="_pFsfA">Đã lưu tất cả thay đổi</div><div id="_r_28_" aria-hidden="true" class="_pFsfA">Thêm trang</div><div id="_r_2b_" aria-hidden="true" class="_pFsfA">Thêm loại trang</div><div id="_r_2d_" aria-hidden="true" class="_pFsfA">Ẩn hình thu nhỏ của trang</div><div id="_r_2f_" aria-hidden="true" class="_pFsfA">Dạng xem lưới</div><div id="_r_2j_" aria-hidden="true" class="_pFsfA">Trang chủ</div><div id="_r_35_" aria-hidden="true" class="_pFsfA">Tải lên</div><div id="_r_37_" aria-hidden="true" class="_pFsfA">Trò chuyện bằng giọng nói</div><div id="_r_39_" aria-hidden="true" class="_pFsfA">Gửi</div><div id="_r_47_" aria-hidden="true" class="_pFsfA">Xem toàn màn hình</div><div id="_r_4j_" aria-hidden="true" class="_pFsfA">Trợ lý AI</div><div id="_r_5r_" aria-hidden="true" class="_pFsfA">Phân tích</div><div id="_r_5t_" aria-hidden="true" class="_pFsfA">Xem toàn màn hình</div><div id="_r_5v_" aria-hidden="true" class="_pFsfA">Tất cả các chế độ thuyết trình</div><div id="_r_64_" aria-hidden="true" class="_pFsfA">Chia sẻ</div><div id="_r_63_" class="_pFsfA">Nút này sẽ mở menu có tất cả các tùy chọn chia sẻ và in thiết kế.</div><div id="_r_95_" aria-hidden="true" class="_pFsfA">Thu gọn</div><div id="_r_9m_" aria-hidden="true" class="_pFsfA">Hiển thị bộ lọc</div><div id="_r_9j_" class="_pFsfA">Trong khi bạn nhập vào mục này, các đề xuất sẽ xuất hiện bên dưới</div><div id="_r_co_" aria-hidden="true" class="_pFsfA">Chia tách</div><div id="_r_cq_" aria-hidden="true" class="_pFsfA">Âm lượng</div><div id="_r_cs_" aria-hidden="true" class="_pFsfA">Xóa 1 bản nhạc</div><div id="_r_cu_" aria-hidden="true" class="_pFsfA">Tạo bản sao 1 bản nhạc</div><div id="_r_d0_" aria-hidden="true" class="_pFsfA">Xóa 1 bản nhạc</div><div id="_r_d2_" aria-hidden="true" class="_pFsfA">Thêm</div><div id="_r_dn_" aria-hidden="true" class="_pFsfA">Tôi thích ứng dụng này</div><div id="_r_dp_" aria-hidden="true" class="_pFsfA">Tôi không thích ứng dụng này</div><div id="_r_e3_" aria-hidden="true" class="_pFsfA">Không thể chỉnh sửa trang</div><div id="_r_gq_" aria-hidden="true" class="_pFsfA">Google Drive</div><div id="_r_gs_" aria-hidden="true" class="_pFsfA">Google Photos</div><div id="_r_gu_" aria-hidden="true" class="_pFsfA">Dropbox</div><div id="_r_h0_" aria-hidden="true" class="_pFsfA">Klaviyo</div><div id="_r_h2_" aria-hidden="true" class="_pFsfA">Instagram</div><div id="_r_h4_" aria-hidden="true" class="_pFsfA">Shopify Connect</div></body><en2vi-host class="corom-element" version="3" style="all: initial; position: absolute; top: 0; left: 0; right: 0; height: 0; margin: 0; text-align: left; z-index: 10000000000; pointer-events: none; border: none; display: block"><template shadowrootmode="open"><style>@import "chrome-extension://gfgbmghkdjckppeomloefmbphdfmokgd/css/common.css";
